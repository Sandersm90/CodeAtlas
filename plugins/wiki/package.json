{
  "name": "@synnode/codeatlas",
  "version": "1.4.2",
  "description": "MCP server for per-project markdown knowledge base with semantic + keyword search",
  "main": "dist/index.js",
  "bin": {
    "codeatlas": "./dist/cli.js"
  },
  "files": [
    "dist/**",
    "scripts/**",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/postbuild.js",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "better-sqlite3": "^9.6.0",
    "glob": "^10.4.5",
    "gray-matter": "^4.0.3",
    "natural": "^6.12.0",
    "sqlite-vec": "^0.1.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/natural": "^5.1.5",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/synnode/codeatlas.git"
  },
  "homepage": "https://github.com/synnode/codeatlas#readme",
  "engines": {
    "node": ">=18.0.0"
  }
}
