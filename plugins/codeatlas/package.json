{
  "name": "@synnode/codeatlas",
  "version": "1.4.10",
  "description": "MCP server for per-project markdown knowledge base with semantic + keyword search",
  "main": "dist/index.js",
  "bin": {
    "codeatlas": "dist/cli.js"
  },
  "files": [
    "dist/**",
    "scripts/**",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/postbuild.js",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "postinstall": "node scripts/postinstall.js",
    "release": "node scripts/release.js",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "natural": "^8.1.1",
    "sqlite-vec": "^0.1.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/synnode/codeatlas.git"
  },
  "homepage": "https://github.com/synnode/codeatlas#readme",
  "engines": {
    "node": ">=18.0.0"
  }
}
